# Kamal reads this file (via your shell) and forwards referenced values to
# the containers. Do NOT commit real values — the committed version only
# documents which env vars are required.
#
# Local workflow:
#   1. Copy this file to .kamal/secrets.local (gitignored).
#   2. Fill in real values.
#   3. Source it before running kamal: `set -a; source .kamal/secrets.local; set +a`.
# CI workflow: inject these as masked environment variables.

# Docker Hub access token used to push/pull the image.
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY
ELEVENLABS_API_KEY=$ELEVENLABS_API_KEY

# Bearer token gating /, /episodes, /edit, /publish. /feed.xml and /audio/*
# stay public so podcast apps can fetch the feed.
# Generate once with: openssl rand -hex 32
AUTH_TOKEN=$AUTH_TOKEN

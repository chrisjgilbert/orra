# Copy to .kamal/secrets and fill in. .kamal/secrets is gitignored.
# Kamal sources this file when reading the `secret:` env list above.

KAMAL_REGISTRY_PASSWORD=$(op read "op://Personal/ghcr/token")

ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=xi-...
OPENAI_API_KEY=sk-...
# Bearer token required for /, /episodes, /edit, /publish.
# /feed.xml and /audio/* stay public so podcast apps can fetch them.
AUTH_TOKEN=$(openssl rand -hex 32)

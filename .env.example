# Local development. Copy to .env and fill in.

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Choose 'elevenlabs' or 'openai'.
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=xi-...
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
OPENAI_API_KEY=sk-...
OPENAI_VOICE=alloy

# Where to put the SQLite db and audio files. Local dev defaults to ./data.
DB_PATH=./data/orra.sqlite3
AUDIO_DIR=./data/audio

# Used in the RSS feed's enclosure URLs.
BASE_URL=http://localhost:8000

FEED_TITLE=Orra Podcast
FEED_DESCRIPTION=Auto-generated single-voice episodes
FEED_AUTHOR=Me

# Bearer token for the web UI. Leave blank to disable auth (NOT recommended).
AUTH_TOKEN=dev-token
